<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App.AgendaPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App"    
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>

        <!-- Gradient background -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFD700" Offset="0"/>
                <GradientStop Color="#000000" Offset="1"/>gfyt
            </LinearGradientBrush>
        </Grid.Background>

        <!-- 
            Main content grid with 3 rows:
            Row 0 = header
            Row 1 = month navigation
            Row 2 = calendar + appointments panel
        -->
        <Grid Padding="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border
    Background="#CC000000"
    CornerRadius="18"
    Padding="20"
    Margin="0,0,0,25">

                <Grid ColumnSpacing="15">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Create button -->

                    <Button
            Content="+ Afspraak"
            Height="40"
            Padding="15,5"
            Click="Button_Click_Create"
            CornerRadius="10"
            Margin="0,0,10,0"/>

                    <!-- ICS import button -->
                    <Button
            Content="ICS import"
            Grid.Column="1"
            Height="40"
            Padding="15,5"
            Click="Button_Click_ImportIcs"
            CornerRadius="10"
            Margin="0,0,10,0"/>

                    <!-- Client filter -->

                    <ComboBox
            x:Name="ClientComboBox"
            Grid.Column="2"
            Height="40"
            DisplayMemberPath="Name"
            PlaceholderText="Select client..."
            SelectionChanged="ClientComboBox_SelectionChanged"/>

                    <!-- Title -->

                    <TextBlock
            Grid.Column="2"
            Text="Mart's Calendar"
            VerticalAlignment="Center"
            FontSize="22"
            FontWeight="SemiBold"
            Foreground="White"/>

                </Grid>
            </Border>

            <!-- MONTH / YEAR NAVIGATION -->
            <Border
                Grid.Row="1"
                Background="#AA000000"
                CornerRadius="14"
                Padding="14"
                Margin="0,0,0,20">

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="14">

                    <!-- Go to previous year -->
                    <Button Content="≪"
                            Click="PreviousYear_Click"
                            Foreground="Black"/>

                    <!-- Go to previous month -->
                    <Button Content="‹"
                            Click="PreviousMonth_Click"
                            Foreground="Black"/>

                    <!-- Text that shows current month and year -->
                    <TextBlock x:Name="MonthYearText"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#FFD700"
                               VerticalAlignment="Center"/>

                    <!-- Go to next month -->
                    <Button Content="›"
                            Click="NextMonth_Click"
                            Foreground="Black"/>

                    <!-- Go to next year -->
                    <Button Content="≫"
                            Click="NextYear_Click"
                            Foreground="Black"/>
                </StackPanel>
            </Border>
            <!-- MAIN CONTENT -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- CALENDAR AREA -->
                <Border
                    Background="White"
                    CornerRadius="18"
                    Padding="12"
                    Margin="0,0,25,0">


                    <!-- 
                        Calendar control.
                        - Single date selection
                        - SelectedDatesChanged runs when a user clicks a date
                        - DayItemChanging runs while calendar day cells are created
                          so we can mark days that contain appointments
                    -->
                    <CalendarView
                        x:Name="CalendarControl"
                        SelectionMode="Single"
                        SelectedDatesChanged="CalendarControl_SelectedDatesChanged"
                        CalendarViewDayItemChanging="CalendarControl_DayItemChanging"
                        Width="650"
                        Height="420"/>
                </Border>

                <!-- APPOINTMENTS PANEL -->
                <Border
                    Grid.Column="1"
                    Background="#CCFFFFFF"
                    CornerRadius="18"
                    Padding="18">

                    <StackPanel>
                        <!-- Panel title -->
                        <TextBlock
                            Text="Appointments on selected day"
                            FontSize="22"
                            FontWeight="Bold"
                            Foreground="Black"
                            Margin="0,0,0,12"/>

                        <!-- Divider line -->
                        <Border Height="1"
                                Background="#FFD700"
                                Opacity="0.6"
                                Margin="0,0,0,12"/>

                        <!-- 
                            This text shows the appointment status of the selected date.
                            Example:
                            - Select a date to view appointments.
                            - There are 2 appointment(s) on this day.
                            - No appointments on this day.
                        -->
                        <TextBlock x:Name="SelectedDayStatusText"
                                   Text="Select a date to view appointments."
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="Black"
                                   Margin="0,0,0,12"/>

                        <Button
                            x:Name="GenerateIcsButton"
                            Content="Genereer ICS voor geselecteerde dag"
                            Height="40"
                            Margin="0,0,0,12"
                            CornerRadius="10"
                            Click="Button_Click_GenerateIcs"/>

                        <!-- Scrollable list of appointments -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="DayAppointmentsControl">

                                <ItemsControl.ItemTemplate>
                                    <!-- 
                                        Each item in this list is one appointment.
                                        The model type is still local:Melding because your database/entity
                                        is probably still named Melding.
                                        But in the UI and code meaning we call them appointments.
                                    -->
                                    <DataTemplate x:DataType="local:Appointment">
                                        <Border
                                            Background="White"
                                            CornerRadius="14"
                                            Padding="14"
                                            Margin="0,0,0,12"
                                            BorderBrush="#E0E0E0"
                                            BorderThickness="1">

                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Klant"
                                                           FontSize="12"
                                                           Foreground="Black"/>
                                                <TextBlock Text="{x:Bind Client.Name}"
                                                           FontWeight="Bold"
                                                           Foreground="Black"/>

                                                <TextBlock Text="Probleem"
                                                           FontSize="12"
                                                           Foreground="Black"/>
                                                <TextBlock Text="{x:Bind ProblemDescription}"
                                                           FontWeight="Bold"
                                                           Foreground="Black"/>

                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>

                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>

</Page>
