<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App.CreatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Padding="20" Spacing="12">

        <ComboBox x:Name="ClientComboBox"
                  Header="Client"
                  DisplayMemberPath="Name"
                  SelectionChanged="ClientComboBox_SelectionChanged"/>

        <ComboBox x:Name="ApplicationComboBox"
                  Header="Application"
                  DisplayMemberPath="Name"
                  SelectionChanged="ApplicationComboBox_SelectionChanged"/>

        <TextBox x:Name="DescriptionTextBox"
                 Header="Beschrijving"
                 TextChanged="DescriptionTextBox_TextChanged"/>
        <DatePicker x:Name="DateDatePicker" />

        <Button Content="Opslaan" Click="Button_Click_Save"/>
        <Button Content="Terug" Click="Button_Click_GoBack"/>

    </StackPanel>
</Page>
