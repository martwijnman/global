<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TradeHubApp.Order.OverviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TradeHubApp.Order"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:TradeHubApp.Data"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="20">
            <TextBlock Text="Bestellingen"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Margin="0,0,0,20"/>

            <ListView x:Name="OrderListView">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Order">
                        <Border Background="#1F1F1F"
                                CornerRadius="10"
                                Padding="16"
                                Margin="0,0,0,10">
                            <StackPanel Spacing="10">
                                <TextBlock Text="{x:Bind Product.Name}"
                                           FontSize="18"
                                           Foreground="White"/>

                                <Button Content="Bekijk detail"
                                        Click="Button_Click_Detail"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </ScrollViewer>
</Page>
